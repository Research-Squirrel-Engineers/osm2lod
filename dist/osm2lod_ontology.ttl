    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range owl:Thing .

osm2lod:osmtag__survey__date a owl:DatatypeProperty ;
    rdfs:label "OSM tag: survey date"@en ;
    rdfs:comment "OSM tag 'survey:date' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:date .

osm2lod:osmtag__survey_point__structure a owl:DatatypeProperty ;
    rdfs:label "OSM tag: survey point structure"@en ;
    rdfs:comment "OSM tag 'survey_point:structure' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__tourism a owl:DatatypeProperty ;
    rdfs:label "OSM tag: tourism type"@en ;
    rdfs:comment "OSM tag 'tourism' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__url a owl:ObjectProperty ;
    rdfs:label "OSM tag: URL"@en ;
    rdfs:comment "OSM tag 'url' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range owl:Thing .

osm2lod:osmtag__volcano__status a owl:DatatypeProperty ;
    rdfs:label "OSM tag: volcano status"@en ;
    rdfs:comment "OSM tag 'volcano:status' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__volcano__type a owl:DatatypeProperty ;
    rdfs:label "OSM tag: volcano type"@en ;
    rdfs:comment "OSM tag 'volcano:type' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__water a owl:DatatypeProperty ;
    rdfs:label "OSM tag: water feature type"@en ;
    rdfs:comment "OSM tag 'water' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__water_source a owl:DatatypeProperty ;
    rdfs:label "OSM tag: water source"@en ;
    rdfs:comment "OSM tag 'water_source' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__website a owl:ObjectProperty ;
    rdfs:label "OSM tag: website URL"@en ;
    rdfs:comment "OSM tag 'website' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range owl:Thing .

osm2lod:osmtag__wikidata a owl:DatatypeProperty ;
    rdfs:label "OSM tag: Wikidata QID (tag)"@en ;
    rdfs:comment "OSM tag 'wikidata' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__wikimedia_commons a owl:ObjectProperty ;
    rdfs:label "OSM tag: Wikimedia Commons file (tag)"@en ;
    rdfs:comment "OSM tag 'wikimedia_commons' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range owl:Thing .

osm2lod:osmtag__wikipedia a owl:DatatypeProperty ;
    rdfs:label "OSM tag: Wikipedia article (tag)"@en ;
    rdfs:comment "OSM tag 'wikipedia' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

geosparql:asWKT a owl:DatatypeProperty ;
    rdfs:label "as WKT"@en ;
    rdfs:comment "GeoSPARQL WKT literal representing the geometry of an OSM entity (CRS: EPSG:4326, format: POINT(lon lat))."@en ;
    rdfs:domain geosparql:Geometry ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range geosparql:wktLiteral .

geosparql:hasGeometry a owl:ObjectProperty ;
    rdfs:label "has geometry"@en ;
    rdfs:comment "Links an OSM entity to its GeoSPARQL geometry node."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range geosparql:Geometry .

owl:sameAs a owl:ObjectProperty ;
    rdfs:label "same as (Wikidata)"@en ;
    rdfs:comment "owl:sameAs link to the corresponding Wikidata entity (Q-item)."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range <http://www.wikidata.org/entity/Q35120> .

foaf:primaryTopic a owl:ObjectProperty ;
    rdfs:label "primary topic"@en ;
    rdfs:comment "Links an osm2lod record to the canonical OpenStreetMap URI of the original element."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range owl:Thing .

osm2lod:Dataset a owl:Class ;
    rdfs:label "osm2lod Dataset"@en ;
    rdfs:comment "A DCAT dataset produced by an osm2lod export run."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso dcat:Dataset ;
    rdfs:subClassOf dcat:Dataset .

osm2lod:OSMEntity a owl:Class ;
    rdfs:label "OSM Entity"@en ;
    rdfs:comment "Abstract superclass for all OpenStreetMap features represented as Linked Data."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso dcat:Dataset ;
    rdfs:subClassOf dcat:Dataset .

osm2lod:ontology a owl:Ontology ;
    rdfs:label "osm2lod Ontology"@en ;
    dcterms:created "2026-03-28T12:19:05.841743+00:00"^^xsd:dateTime ;
    dcterms:creator "Research Squirrel Engineers" ;
    dcterms:description "Vocabulary for representing OpenStreetMap features as Linked Data, aligned to CIDOC-CRM, GeoSPARQL, DCAT and Dublin Core."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "osm2lod – OSM to Linked Open Data Vocabulary"@en ;
    owl:imports <http://www.opengis.net/ont/geosparql> ;
    owl:versionInfo "2026-03-28T12:19:05.841743+00:00" .

