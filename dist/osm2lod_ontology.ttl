    rdfs:label "OSM tag: denomination"@en ;
    rdfs:comment "OSM tag 'denomination' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__description a owl:DatatypeProperty ;
    rdfs:label "OSM tag: description"@en ;
    rdfs:comment "OSM tag 'description' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__ele a owl:DatatypeProperty ;
    rdfs:label "OSM tag: elevation"@en ;
