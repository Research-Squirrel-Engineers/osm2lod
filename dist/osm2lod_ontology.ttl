@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix osm2lod: <http://research-squirrel-engineers.github.io/osm2lod/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Links an OSM entity record to the osm2lod Dataset it was exported in."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range osm2lod:Dataset .

osm2lod:Benchmark a owl:Class ;
    rdfs:label "Benchmark"@en ;
    rdfs:comment "An Ordnance Survey benchmark / geodetic survey point with a Wikimedia Commons photograph."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E22_Human_Made_Object ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E22_Human_Made_Object .

osm2lod:CI_Findspot a owl:Class ;
    rdfs:label "CI Findspot"@en ;
    rdfs:comment "A Palaeolithic cave or rock-shelter site yielding Continuum of Innovation (CI) artefacts."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E55_Place ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E55_Place .

osm2lod:CoreProfile a owl:Class ;
    rdfs:label "Core Profile"@en ;
    rdfs:comment "A drill-core borehole profile associated with a volcanic maar site."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E55_Place ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E55_Place .

osm2lod:HogbackStone a owl:Class ;
    rdfs:label "Hogback Stone"@en ;
    rdfs:comment "A Viking-Age carved recumbent monument, typically found in northern England and Scotland."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E22_Human_Made_Object ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E22_Human_Made_Object .

osm2lod:HolyWell a owl:Class ;
    rdfs:label "Holy Well"@en ;
    rdfs:comment "A sacred water site, typically a natural spring venerated in folk or religious tradition."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E26_Physical_Feature ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E26_Physical_Feature .

osm2lod:Maar a owl:Class ;
    rdfs:label "Maar"@en ;
    rdfs:comment "A low-relief volcanic crater formed by a phreatomagmatic eruption."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E55_Place ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E55_Place .

osm2lod:OghamStone a owl:Class ;
    rdfs:label "Ogham Stone"@en ;
    rdfs:comment "An early medieval inscribed standing stone bearing Ogham script."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E22_Human_Made_Object ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E22_Human_Made_Object .

osm2lod:RomanSite a owl:Class ;
    rdfs:label "Roman Site"@en ;
    rdfs:comment "A Roman-period archaeological site."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E26_Physical_Feature ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E26_Physical_Feature .

osm2lod:SisalSite a owl:Class ;
    rdfs:label "SISAL Site"@en ;
    rdfs:comment "A speleothem cave site included in the SISAL (Speleothem Isotopes Synthesis and Analysis) database."@en ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:seeAlso crm:E26_Physical_Feature ;
    rdfs:subClassOf osm2lod:OSMEntity,
        crm:E26_Physical_Feature .

osm2lod:exportType a owl:DatatypeProperty ;
    rdfs:label "export type"@en ;
    rdfs:comment "Identifies the osm2lod export category this entity belongs to (e.g. 'ogham', 'holywells', 'sisal')."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__access a owl:DatatypeProperty ;
    rdfs:label "OSM tag: access restriction"@en ;
    rdfs:comment "OSM tag 'access' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__alt_name a owl:DatatypeProperty ;
    rdfs:label "OSM tag: alternative name"@en ;
