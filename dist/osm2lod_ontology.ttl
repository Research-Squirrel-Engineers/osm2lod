    rdfs:label "OSM tag: international name"@en ;
    rdfs:comment "OSM tag 'int_name' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

osm2lod:osmtag__loc_name a owl:DatatypeProperty ;
