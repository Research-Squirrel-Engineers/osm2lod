    rdfs:comment "OSM tag 'benchmark' mapped as an osm2lod datatype property."@en ;
    rdfs:domain osm2lod:OSMEntity ;
    rdfs:isDefinedBy osm2lod:ontology ;
    rdfs:range xsd:string .

